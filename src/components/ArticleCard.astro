---
import Tag from './Tag.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tags: string[];
  slug: string;
  featured?: boolean;
  lang?: 'es' | 'en';
}

const { title, description, pubDate, tags, slug, featured = false, lang = 'es' } = Astro.props;

const formattedDate = pubDate.toLocaleDateString(lang === 'es' ? 'es-ES' : 'en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric'
});

const prefix = lang === 'en' ? '/en' : '';
const readMoreLabel = lang === 'es' ? 'Leer más' : 'Read more';
const featuredLabel = lang === 'es' ? 'Destacado' : 'Featured';
---

<a href={`${prefix}/articles/${slug}`} class={`article-card ${featured ? 'featured' : ''}`}>
  {featured && <span class="featured-badge">{featuredLabel}</span>}

  <div class="tags-row">
    {tags.map((tag) => (
      <Tag name={tag} />
    ))}
  </div>

  <h3 class="title">{title}</h3>

  <p class="description">{description}</p>

  <div class="meta">
    <span class="date">{formattedDate}</span>
    <span class="separator">&middot;</span>
    <span class="read-more">{readMoreLabel}</span>
  </div>
</a>

<style>
  .article-card {
    display: block;
    position: relative;
    padding: var(--space-lg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-bg);
    text-decoration: none;
    color: inherit;
    transition:
      transform var(--duration-normal) var(--ease-out),
      box-shadow var(--duration-normal) var(--ease-out),
      border-color var(--duration-normal) var(--ease-out);
  }

  .article-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 24px -8px rgba(0, 0, 0, 0.15);
    border-color: var(--color-border-strong);
  }

  .article-card.featured {
    border: 2px solid var(--color-fg);
  }

  .featured-badge {
    position: absolute;
    top: var(--space-md);
    right: var(--space-md);
    font-family: var(--font-mono);
    font-size: 0.625rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-bg);
    background: var(--color-fg);
    padding: var(--space-xs) var(--space-sm);
    border-radius: var(--radius-sm);
  }

  .tags-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    margin-bottom: var(--space-md);
  }

  .title {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 400;
    color: var(--color-fg);
    margin-bottom: var(--space-sm);
    line-height: 1.3;
    letter-spacing: -0.02em;
  }

  @media (max-width: 768px) {
    .title {
      font-size: 1.25rem;
    }
  }

  .description {
    font-size: 0.875rem;
    color: var(--color-fg-muted);
    line-height: 1.6;
    margin-bottom: var(--space-md);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .meta {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-fg-subtle);
  }

  .separator {
    color: var(--color-border-strong);
  }

  .read-more {
    color: var(--color-fg-muted);
    transition: color var(--duration-fast) var(--ease-out);
  }

  .article-card:hover .read-more {
    color: var(--color-fg);
  }
</style>